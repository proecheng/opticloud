# OptiCloud — 本地开发环境变量模板
# 复制为 .env 后填值（.env 已 .gitignore）

# ===== Postgres =====
POSTGRES_USER=opticloud
POSTGRES_PASSWORD=opticloud_dev
POSTGRES_DB=opticloud_dev
DATABASE_URL=postgresql+asyncpg://opticloud:opticloud_dev@localhost:5432/opticloud_dev

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== Vault (dev mode, ONLY for local) =====
VAULT_ADDR=http://localhost:8200
VAULT_DEV_TOKEN=opticloud-dev-token

# 风控 / API Key HMAC pepper (Vault HSM 生产；dev fallback)
# Constraint C9: TDE 全环境启用 + CI Vault dev mode + 启动时自动注入 KMS key
API_KEY_HMAC_PEPPER_DEV=dev-pepper-do-not-use-in-prod-32-bytes-xxxxxxxx

# JWT signing (Ed25519 - 生产从 Vault 拉；dev fallback)
# P40 mTLS + D8 EdDSA
JWT_PRIVATE_KEY_PATH=./infra/local-init/dev-jwt-ed25519.key
JWT_PUBLIC_KEY_PATH=./infra/local-init/dev-jwt-ed25519.pub
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ===== MinIO (S3-compatible) =====
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=opticloud
MINIO_ROOT_PASSWORD=opticloud_dev
MINIO_BUCKET_DEFAULT=opticloud-dev

# ===== LocalStack (AWS S3 / KMS / SQS mock) =====
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=cn-north-1

# ===== OpenTelemetry =====
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAMESPACE=opticloud

# ===== Service ports =====
API_GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
SOLVER_ORCHESTRATOR_PORT=8002
BILLING_SERVICE_PORT=8003
CHAT_SERVICE_PORT=8004
CRITIC_SERVICE_PORT=8005
SANDBOX_RUNNER_PORT=8006
CAPABILITY_REGISTRY_PORT=8007
REPRO_SERVICE_PORT=8008

# ===== LLM (Chat / Critic) =====
# DeepSeek 主路径 / Qwen-Max incident fallback
DEEPSEEK_API_KEY=
QWEN_API_KEY=
LLM_PROVIDER_DEFAULT=deepseek-v3.5

# ===== Compliance (M0 wk1 待 ramp-up) =====
# AIGC 备案中介费 ¥3-8 万 / 等保 2.0 二级 M3 评测启动
AIGC_FILING_STATUS=pending  # pending / approved / fallback_engaged
